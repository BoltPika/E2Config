        {
          "Rules": [
            {
              "RuleSource": "// 全局前置1：场景屏蔽 + 自动清空标记\nif (State.IsInTown || State.IsInHideout || State.IsAnyLargePanelOpen\n    || State.IsAnyFullscreenPanelOpen || State.IsInEscapeMenu\n    || State.IsChatOpen || State.NPC对话打开 || State.祭坛窗口打开 || State.符文窗口打开)\n{\n    // 切场景直接清空所有flag\n    return new ISideEffect[]\n    {\n        new ResetFlagSideEffect(\"弹幕\"),\n        new ResetFlagSideEffect(\"赏金\"),\n        new ResetFlagSideEffect(\"回旋延迟\")\n    };\n}\n\n// ==================== 基础数据读取 ====================\nbool 范围内50码有怪 = State.Monsters(50, ReAgent.State.MonsterRarity.Any).Any(m => m.IsAlive);\nbool 范围内100码有怪 = State.Monsters(100, ReAgent.State.MonsterRarity.Any).Any(m => m.IsAlive);\nbool 范围内300码有怪 = State.Monsters(300, ReAgent.State.MonsterRarity.Any).Any(m => m.IsAlive);\nbool 范围内1000码有怪 = State.Monsters(1000, ReAgent.State.MonsterRarity.Any).Any(m => m.IsAlive);\nbool 存在任意怪物 =  范围内50码有怪 || 范围内100码有怪 || 范围内300码有怪 || 范围内1000码有怪;\n\nbool 拥有猫头鹰羽毛buff = State.Buffs.Has(\"owl_feather\");\ndouble 猫头鹰实际层数 = 拥有猫头鹰羽毛buff ? State.Buffs[\"owl_feather\"].Charges : 0d;\nbool 猫头鹰达标 = 猫头鹰实际层数 >= 1d;\n\nbool 弹幕可释放 = State.Skills[\"BarragePlayer\"].CanBeUsed;\nbool 弹幕buff激活 = State.Buffs.Has(\"empower_barrage_visual\");\nbool 赏金buff激活 = State.Buffs[\"primal_bounty_buff\"].TimeLeft>0;\nbool 回旋斩达标 = State.Buffs[\"spear_sandstorm_allies\"].FlaskSlot >= 9;\n\n// 全局前置2：buff消失/无怪物时自动清理flag\nif (!弹幕buff激活 && !赏金buff激活 && State.IsFlagSet(\"弹幕\") && State.IsFlagSet(\"赏金\"))\n{\n    return new ISideEffect[]\n    {\n        new ResetFlagSideEffect(\"弹幕\"),\n        new ResetFlagSideEffect(\"赏金\")\n    };\n}\nif (!弹幕buff激活 && State.IsFlagSet(\"弹幕\"))\n{\n    return new ISideEffect[]\n    {\n        new ResetFlagSideEffect(\"弹幕\")\n    };\n}\nif (!赏金buff激活 && State.IsFlagSet(\"赏金\"))\n{\n    return new ISideEffect[]\n    {\n        new ResetFlagSideEffect(\"赏金\")\n    };\n}\n// 读取标记\nbool 弹幕操作 = State.IsFlagSet(\"弹幕\");\nbool 赏金操作 = State.IsFlagSet(\"赏金\");\nbool 回旋延迟 = State.IsFlagSet(\"回旋延迟\");\n\n\n// ==================== 优先级1：Q补弹幕 ====================\nif (!弹幕操作 && 弹幕可释放 && !弹幕buff激活 && 存在任意怪物)\n{\n    return new ISideEffect[]\n    {\n        new SetFlagSideEffect(\"弹幕\"),\n        new PressKeySideEffect(System.Windows.Forms.Keys.Q),\n        new SetFlagSideEffect(\"回旋延迟\")\n    };\n}\n\n// ==================== 优先级2：Space补赏金（限制3层猫头鹰） ====================\nif (!赏金操作 && 弹幕buff激活 && 猫头鹰实际层数 >= 3 && 范围内1000码有怪 && !范围内100码有怪)\n{\n    return new ISideEffect[]\n    {\n        new SetFlagSideEffect(\"赏金\"),\n        new PressKeySideEffect(System.Windows.Forms.Keys.Space),\n        new SetFlagSideEffect(\"回旋延迟\")\n    };\n}\nif (!赏金操作 && 弹幕buff激活 && 猫头鹰实际层数 >= 2 && 范围内300码有怪 && !范围内100码有怪)\n{\n    return new ISideEffect[]\n    {\n        new SetFlagSideEffect(\"赏金\"),\n        new PressKeySideEffect(System.Windows.Forms.Keys.Space),\n        new SetFlagSideEffect(\"回旋延迟\")\n    };\n}\nif (!赏金操作 && 弹幕buff激活 && 猫头鹰实际层数 >= 1 && 范围内100码有怪 && !范围内50码有怪)\n{\n    return new ISideEffect[]\n    {\n        new SetFlagSideEffect(\"赏金\"),\n        new PressKeySideEffect(System.Windows.Forms.Keys.Space),\n        new SetFlagSideEffect(\"回旋延迟\")\n    };\n}\n// ==================== 优先级3：R放旋风（增加flag防连发） ====================\nif ((弹幕buff激活 || 赏金buff激活) && 范围内100码有怪 && 回旋斩达标 && State.SinceLastActivation(0.1d))\n{\n    return new ISideEffect[]\n    {\n        new PressKeySideEffect(System.Windows.Forms.Keys.R),\n        new SetFlagSideEffect(\"回旋延迟\")\n    };\n}\n\n// ==================== 优先级4：E键叠层/赶路（无怪不触发） ====================\nif (回旋延迟 && State.SinceLastActivation(0.1d))\n{\n    return new ISideEffect[]\n    {\n        new DelayedSideEffect(0.2d, () => new ISideEffect[]\n        {\n            new PressKeySideEffect(System.Windows.Forms.Keys.E),\n            new ResetFlagSideEffect(\"回旋延迟\")\n        })\n    };\n}\nif (State.SinceLastActivation(0.1d))\n{\n    return new ISideEffect[]\n    {\n        new PressKeySideEffect(System.Windows.Forms.Keys.E)\n    };\n}\n// 无操作\nreturn null;",
              "Type": 2,
              "KeyV2": null,
              "SyntaxVersion": 2
            }
          ],
