              "RuleSource": "\"描述\"!=\"赏金、弹幕、回旋3次、100范围有怪\"&\nBuffs.Has(\"primal_bounty_buff\")&\nBuffs.Has(\"empower_barrage_visual\")&\nBuffs[\"spear_sandstorm_allies\"].FlaskSlot>=9&\n识别怪物(100).Any(m => m.IsAlive)&\n按键间隔(0.1)",
